# config.env.example — copy to /etc/ipod-sync/config.env and fill in real values.
#
#   sudo mkdir -p /etc/ipod-sync
#   sudo cp config.env.example /etc/ipod-sync/config.env
#   sudo nano /etc/ipod-sync/config.env
#   sudo chmod 640 /etc/ipod-sync/config.env
#   sudo chown root:jimin /etc/ipod-sync/config.env
#
# This file is sourced by shell scripts AND parsed by the web app, so keep it to
# simple KEY=value lines (no shell expansion, no spaces around '=').

# ── Server user ────────────────────────────────────────────────────────────────
# The regular Linux user that owns the media and runs the services.
SYNC_USER=jimin

# ── Paths (server / NUC) ─────────────────────────────────────────────────────────
# Authoritative music library. Named FLAC by history; may also hold .m4a/.aac.
MUSIC_DIR=/mnt/data/media/music/FLAC
PLAYLIST_DIR=/mnt/data/media/music/Playlists

# iPod mount point (Rockbox, vfat). The sync script derives FLAC/, Playlists/,
# and .scrobbler.log underneath this.
IPOD_MOUNT_PATH=/mnt/data/ipod
# Optional hard override — if set and mounted, used instead of auto-detection.
# IPOD_MOUNT_OVERRIDE=/mnt/data/ipod

# The parent volume that must be healthily mounted before any destructive sync.
# A sentinel file (.mounted_ok) must exist at its root — see docs (mount hardening).
DATA_MOUNT=/mnt/data

# Where logs and the structured event stream live.
LOG_DIR=/var/log/ipod-sync
# Append-only structured event log (JSONL) shown in the web UI.
EVENTS_LOG=/var/log/ipod-sync/events.jsonl

# ── Debounce ─────────────────────────────────────────────────────────────────────
# Seconds of quiet after the last file event before beets runs (album arrives once).
DEBOUNCE_SECS=30

# ── CD flow ───────────────────────────────────────────────────────────────────────
# Apple Music library folder on the Mac (source of CD rips). Used by mac/cd-sync.sh.
MUSIC_APP_DIR=/Users/ben/Music/Music/Media.localized/Music
# NUC host reachable from the Mac (Tailscale IP or MagicDNS name).
NUC_HOST=100.94.158.95
# Transcode ALAC .m4a → .flac after import. Off: you rip AAC, transcoding is pointless.
CD_TRANSCODE_TO_FLAC=false

# ── Web app ─────────────────────────────────────────────────────────────────────
WEB_PORT=8337
# Optional shared token: if set, POST /events must send  X-Event-Token: <this>.
# Leave blank to accept unauthenticated events (fine on a Tailscale-only bind).
EVENT_TOKEN=

# ── Nextcloud (existing torrent path) ────────────────────────────────────────────
NEXTCLOUD_USER=ben
NEXTCLOUD_URL=http://100.94.158.95:8080
NEXTCLOUD_APP_PASSWORD=changeme-app-password

# ── Last.fm ───────────────────────────────────────────────────────────────────────
LASTFM_API_KEY=your-api-key
LASTFM_API_SECRET=your-api-secret
LASTFM_USERNAME=blgondzur
