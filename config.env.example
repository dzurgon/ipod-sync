# Copy this file to /etc/ipod-sync/config.env on the NUC and fill in real values.
# Never commit the real config.env — it is gitignored.

# ── Paths ──────────────────────────────────────────────────────────────────────
MUSIC_DIR=/mnt/data/media/music/FLAC
PLAYLIST_DIR=/mnt/data/media/music/Playlists
IPOD_MUSIC_DIR=/media/ben/IPOD/FLAC
IPOD_PLAYLIST_DIR=/media/ben/IPOD/Playlists
IPOD_SCROBBLER_LOG=/media/ben/IPOD/.scrobbler.log

# ── Nextcloud ─────────────────────────────────────────────────────────────────
# User whose Nextcloud storage holds the music (used for server-side rescan)
NEXTCLOUD_USER=ben
# Base URL of your Nextcloud instance
NEXTCLOUD_URL=http://localhost:8080
# Nextcloud app password (Settings → Security → App passwords)
NEXTCLOUD_APP_PASSWORD=your-nextcloud-app-password-here

# ── Last.fm ──────────────────────────────────────────────────────────────────
LASTFM_API_KEY=your-lastfm-api-key-here
LASTFM_API_SECRET=your-lastfm-api-secret-here
LASTFM_USERNAME=blgondzur
# Session key is written here after first auth run; leave blank initially
LASTFM_SESSION_KEY=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_DIR=/var/log/ipod-sync
